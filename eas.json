{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "20.18.0",
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "EXPO_ROUTER_APP_ROOT": "app"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "extends": "base",
      "distribution": "internal"
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.loamlogger.app",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "22899107125-up6tfvkciit2n1tvs1v9mugrdgue15ui.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "22899107125-us6eeju0mptqq569qq6achnbq3u7c44d.apps.googleusercontent.com",
        "EXPO_PUBLIC_REVENUECAT_API_KEY": "appl_PCpaBxHHtSUMtzvrbyupJifgBgD"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
